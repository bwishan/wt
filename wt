            return 1
            
    except Exception as e:
        print(Colors.error(f"Error pruning worktrees: {e}"), file=sys.stderr)
        return 1


def find_repo_root(path: str = ".") -> Optional[str]:
    """Find the git repository root."""
    try:
        result = subprocess.run(
            ["git", "rev-parse", "--show-toplevel"],
            cwd=path,
            capture_output=True,
            text=True,
            check=True
        )
        return result.stdout.strip()
    except (subprocess.CalledProcessError, FileNotFoundError):
        return None


def create_parser() -> argparse.ArgumentParser:
    """Create the argument parser with subcommands."""
    parser = argparse.ArgumentParser(
        prog='wt',
        description='Minimalist git worktree manager',
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
Examples:
  wt list                    List all worktrees
  wt new feat/dashboard      Create new worktree for feature branch
  wt rm feat/dashboard       Remove worktree
  wt sync                    Sync all worktrees with remote
        """
    )
    
    parser.add_argument('--version', action='version', version=f'wt {__version__}')
    
    subparsers = parser.add_subparsers(dest='command', help='Available commands')
    
    # wt list (with ls alias)
    list_parser = subparsers.add_parser('list', aliases=['ls'], help='List worktrees')
    list_parser.add_argument('--porcelain', action='store_true', help='Script-friendly output')
    
    # wt new
    new_parser = subparsers.add_parser('new', help='Create new worktree')
    new_parser.add_argument('branch', nargs='?', help='Branch name (will prompt if not provided)')
    new_parser.add_argument('--base', help='Base branch/commit (default: origin/main)')
    new_parser.add_argument('--dir', help='Custom directory path')
    new_parser.add_argument('--force', '-f', action='store_true', help='Force creation')
    
    # wt rm
    rm_parser = subparsers.add_parser('rm', help='Remove worktree')
    rm_parser.add_argument('branch', nargs='?', help='Branch name to remove (will prompt if not provided)')
    rm_parser.add_argument('--force', '-f', action='store_true', help='Skip safety checks (allow data loss)')
    rm_parser.add_argument('--yes', '-y', action='store_true', help='Skip confirmation prompts')
    
    # wt sync
    sync_parser = subparsers.add_parser('sync', help='Sync worktrees with remote')
    
    # wt prune
    prune_parser = subparsers.add_parser('prune', help='Prune stale worktree entries')
    
    return parser


async def main():
    """Main entry point."""
    parser = create_parser()
    args = parser.parse_args()
    
    # Check for git availability
    if shutil.which("git") is None:
        print(Colors.error("git not found in PATH"), file=sys.stderr)
        return 1
    
    # Find repository root
    repo_root = find_repo_root(".")
    if repo_root is None:
        print(Colors.error("not inside a git repository"), file=sys.stderr)
        return 1
    
    # Initialize managers
    config = Config(repo_root)
    git = GitManager(repo_root, config)
    
    # Detect base branch
    config.base_ref = await git.detect_base_branch()
    
    # Handle commands
    if args.command is None or args.command in ('list', 'ls'):
        return await cmd_list(git, args)
    elif args.command == 'new':
        return await cmd_new(git, args)
    elif args.command == 'rm':
        return await cmd_rm(git, args)
    elif args.command == 'sync':
        return await cmd_sync(git, args)
    elif args.command == 'prune':
        return await cmd_prune(git, args)
    else:
        parser.print_help()
        return 1


if __name__ == "__main__":
    try:
        exit_code = asyncio.run(main())
        sys.exit(exit_code)
    except KeyboardInterrupt:
        print("\nInterrupted by user", file=sys.stderr)
        sys.exit(130)
    except Exception as e:
        print(Colors.error(f"Unexpected error: {e}"), file=sys.stderr)
        sys.exit(1)